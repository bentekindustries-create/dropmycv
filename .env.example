# Anthropic API — get yours at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Adzuna API — free tier at developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# Jooble API (optional) — free at jooble.org/api/about
JOOBLE_API_KEY=your_jooble_api_key_here

# Brave Search API (optional) — api-dashboard.search.brave.com
BRAVE_API_KEY=your_brave_api_key_here

# Set to true to skip all API calls and return instant fake data.
# Copy this file to .env.local and toggle this to test the UI without spending API credits.
NEXT_PUBLIC_MOCK_MODE=false
